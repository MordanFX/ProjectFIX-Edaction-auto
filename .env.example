APP_ENV=development
LOG_LEVEL=INFO

# Docker deployment defaults. Use a strong password in production.
PROJECTFIX_POSTGRES_USER=projectfix
PROJECTFIX_POSTGRES_PASSWORD=change-this-password
PROJECTFIX_POSTGRES_DB=projectfix
PROJECTFIX_FRONTEND_PORT=8081

# Local PostgreSQL connection. Replace values only in your private .env file.
DATABASE_URL=postgresql+asyncpg://course_user:course_password@localhost:5432/course_platform
DB_ECHO=false

# Leave empty until a BotFather token is available.
TELEGRAM_BOT_TOKEN=
# Keep the default for development. Point this to the local Bot API service on deployment
# to remove Telegram's 20 MB cloud download limit.
TELEGRAM_API_URL=https://api.telegram.org

# Independent Discord learning stream.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Optional: use an existing Discord text/forum channel for private homework threads.
# Leave empty to let /setup_project_fix create/find HOMEWORK -> homework-desk.
DISCORD_HOMEWORK_CHANNEL_ID=
# Optional: Discord role mentioned when a student clicks "Уточнить вопрос".
# Use one shared staff role for admins and curators.
DISCORD_STAFF_ROLE_ID=
# Enable only after Message Content Intent is switched on in Discord Developer Portal.
DISCORD_MESSAGE_CONTENT_ENABLED=false

# Generate a long random value before starting the curator API.
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
